{
  "name": "streakflow",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@streakflow/web",
    "dev:worker": "turbo dev --filter=@streakflow/worker",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:integration": "turbo test:integration",
    "test:e2e": "turbo test:e2e",
    "test:coverage": "turbo test:coverage",
    "db:generate": "npm run --workspace=packages/db db:generate",
    "db:migrate": "npm run --workspace=packages/db db:migrate",
    "db:studio": "npm run --workspace=packages/db db:studio",
    "db:seed": "npm run --workspace=packages/db db:seed",
    "start": "turbo start --filter=@streakflow/web",
    "analyze": "cross-env ANALYZE=true turbo build --filter=@streakflow/web",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "turbo": "^2.1.2",
    "typescript": "^5.5.4"
  },
  "packageManager": "npm@10.8.1",
  "engines": {
    "node": ">=20"
  }
}
